# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` — it is gitignored.

# --- LLM providers (pick at least one) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Email (Resend — primary channel) ---
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# --- SMS (Africa's Talking — warm leads only) ---
AT_USERNAME=
AT_API_KEY=
AT_SHORTCODE=

# --- CRM (HubSpot Developer Sandbox) ---
HUBSPOT_TOKEN=

# --- Scheduling (Cal.com) ---
CALCOM_API_KEY=
CALCOM_BOOKING_URL=

# --- Observability (Langfuse) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Safety kill-switch ---
# Default unset → all outbound routes to staff sink.
# Only program staff set this to "true" after review + Tenacious approval.
ALLOW_REAL_PROSPECT_CONTACT=false
STAFF_SINK_EMAIL=nebiyoua@10academy.org
