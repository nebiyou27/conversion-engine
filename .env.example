# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` — it is gitignored.

# --- LLM providers (pick at least one) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Email (Resend — primary channel) ---
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# --- SMS (Africa's Talking — warm leads only) ---
AT_USERNAME=
AT_API_KEY=
AT_SHORTCODE=
AFRICASTALKING_SENDER_ID=
STAFF_SINK_PHONE_NUMBER=

# --- CRM (HubSpot SDK fallback + HubSpot MCP remote server) ---
HUBSPOT_TOKEN=
USE_HUBSPOT_MCP=false
HUBSPOT_MCP_URL=https://mcp.hubspot.com/
HUBSPOT_MCP_ACCESS_TOKEN=
# Optional tool-name overrides if your MCP app exposes different names.
HUBSPOT_MCP_CREATE_CONTACT_TOOL=
HUBSPOT_MCP_UPDATE_CONTACT_TOOL=

# --- Scheduling (Cal.com) ---
CALCOM_API_KEY=
CALCOM_BOOKING_URL=

# --- Observability (Langfuse) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LOG_LEVEL=INFO
IDEMPOTENCY_CACHE_DIR=data/cache/idempotency

# --- Safety kill-switch ---
# Default unset → all outbound routes to staff sink.
# Only program staff set this to "true" after review + Tenacious approval.
ALLOW_REAL_PROSPECT_CONTACT=false
STAFF_SINK_EMAIL=nebiyoua@10academy.org
